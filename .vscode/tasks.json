{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Stop API server (5179)",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				"pid=$(lsof -t -iTCP:5179 -sTCP:LISTEN 2>/dev/null || true); if [ -n \"${pid:-}\" ]; then kill \"$pid\" || true; fi"
			],
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Start API server (5179) (detached)",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				"set -euo pipefail; cd \"${workspaceFolder}\"; pid=$(lsof -t -iTCP:5179 -sTCP:LISTEN 2>/dev/null || true); if [ -n \"${pid:-}\" ]; then kill \"$pid\" || true; sleep 1; fi; nohup dotnet run --project Picea.Abies.Conduit.Api --no-build --urls http://localhost:5179 > /tmp/abies-conduit-api-5179.log 2>&1 & echo $! > /tmp/abies-conduit-api-5179.pid; echo \"API started (detached). Log: /tmp/abies-conduit-api-5179.log\""
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Show API server log (5179)",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				"if [ -f /tmp/abies-conduit-api-5179.log ]; then tail -n 200 /tmp/abies-conduit-api-5179.log; else echo \"No log file found at /tmp/abies-conduit-api-5179.log\"; fi"
			],
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "OTLP proxy smoke test (API 5179 → Dashboard)",
			"type": "shell",
			"command": "python3 scripts/otlp_smoke_test.py",
			"problemMatcher": [],
			"group": "test"
		},
		{
			"label": "Run E2E tests",
			"type": "shell",
			"command": "dotnet test Picea.Abies.Conduit.Testing.E2E/Picea.Abies.Conduit.Testing.E2E.csproj -c Debug -v minimal",
			"problemMatcher": [
				"$msCompile"
			],
			"group": "test"
		},
		{
			"label": "Start API server (5179)",
			"type": "shell",
			"command": "dotnet run --project Picea.Abies.Conduit.Api --no-build --urls http://localhost:5179",
			"args": [],
			"isBackground": true,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Start Frontend (5209)",
			"type": "shell",
			"command": "dotnet run --project Picea.Abies.Conduit.Wasm --no-build",
			"args": [],
			"isBackground": true,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Run E2E tests (headed) full suite",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"test",
				"Picea.Abies.Conduit.Testing.E2E/Picea.Abies.Conduit.Testing.E2E.csproj",
				"-c",
				"Debug",
				"-v",
				"minimal"
			],
			"options": {
				"env": {
					"HEADED": "1",
					"PW_SLOWMO_MS": "150",
					"PWDEBUG": "0",
					"PLAYWRIGHT_BROWSERS_PATH": "0"
				}
			},
			"isBackground": false,
			"problemMatcher": [
				"$msCompile"
			],
			"group": "test"
		},
		{
			"label": "Run E2E Favorite and Pagination tests",
			"type": "shell",
			"command": "dotnet test Picea.Abies.Conduit.Testing.E2E/Picea.Abies.Conduit.Testing.E2E.csproj -v minimal --filter \"FullyQualifiedName~Picea.Abies.Conduit.Testing.E2E.FavoriteTests|FullyQualifiedName~Picea.Abies.Conduit.Testing.E2E.PaginationTests\"",
			"isBackground": false,
			"problemMatcher": [
				"$msCompile"
			],
			"group": "test"
		},
		{
			"label": "Run E2E (headed + slowmo) Favorite and Pagination",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"test",
				"Picea.Abies.Conduit.Testing.E2E/Picea.Abies.Conduit.Testing.E2E.csproj",
				"-v",
				"minimal",
				"--filter",
				"FullyQualifiedName~FavoriteTests|FullyQualifiedName~PaginationTests"
			],
			"options": {
				"env": {
					"HEADED": "1",
					"PW_SLOWMO_MS": "150",
					"PWDEBUG": "0",
					"PLAYWRIGHT_BROWSERS_PATH": "0"
				}
			},
			"isBackground": false,
			"problemMatcher": [
				"$msCompile"
			],
			"group": "test"
		},
		{
			"label": "Run single E2E test",
			"type": "shell",
			"command": "dotnet test Picea.Abies.Conduit.Testing.E2E/Picea.Abies.Conduit.Testing.E2E.csproj --filter FullyQualifiedName~Picea.Abies.Conduit.Testing.E2E.PaginationTests.CanNavigateArticlePages -l trx",
			"isBackground": false,
			"problemMatcher": [
				"$msCompile"
			],
			"group": "test"
		},
		{
			"label": "Start Conduit AppHost",
			"type": "shell",
			"command": "dotnet run --project Picea.Abies.Conduit.AppHost/Picea.Abies.Conduit.AppHost.csproj",
			"isBackground": true,
			"problemMatcher": [],
			"group": "build"
		}
	]
}