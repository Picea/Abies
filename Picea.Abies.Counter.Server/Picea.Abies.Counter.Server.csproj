<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <InterceptorsNamespaces>$(InterceptorsNamespaces);Praefixum</InterceptorsNamespaces>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Picea.Abies.Counter\Picea.Abies.Counter.csproj" />
    <ProjectReference Include="..\Picea.Abies.Server.Kestrel\Picea.Abies.Server.Kestrel.csproj" />
  </ItemGroup>

  <!-- Copy the canonical counter.css from the shared Counter project before build/publish. -->
  <Target Name="SyncCounterCss" BeforeTargets="Build;ComputeFilesToPublish"
          Inputs="..\Picea.Abies.Counter\wwwroot\counter.css"
          Outputs="wwwroot\counter.css">
    <Copy SourceFiles="..\Picea.Abies.Counter\wwwroot\counter.css"
          DestinationFiles="wwwroot\counter.css" />
  </Target>

</Project>
