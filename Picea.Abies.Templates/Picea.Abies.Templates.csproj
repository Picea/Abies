<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <PackageType>Template</PackageType>
    <PackageVersion>1.0.0</PackageVersion>
    <PackageId>Picea.Abies.Templates</PackageId>
    <Title>Picea Abies Templates</Title>
    <Authors>Maurice CGP Peters</Authors>
    <Description>Templates for creating Abies MVU-style web applications with .NET. Use 'dotnet new abies-browser' for WebAssembly or 'dotnet new abies-server' for server-side rendering.</Description>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/Picea/Abies</PackageProjectUrl>
    <RepositoryUrl>https://github.com/Picea/Abies.git</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>dotnet-new;templates;picea;abies;webassembly;wasm;mvu;elm;ssr;server</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageReleaseNotes>https://github.com/Picea/Abies/releases</PackageReleaseNotes>
    <TargetFramework>netstandard2.0</TargetFramework>

    <!-- Template package settings -->
    <IncludeContentInPack>true</IncludeContentInPack>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <ContentTargetFolders>content</ContentTargetFolders>
    <NoDefaultExcludes>true</NoDefaultExcludes>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="templates\**\*" Exclude="templates\**\bin\**;templates\**\obj\**" />
    <Compile Remove="**\*" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="" />
  </ItemGroup>

  <!--
    Sync abies.js and abies-otel.js from the canonical source (Picea.Abies.Browser/wwwroot/)
    into every browser template's wwwroot/ before build/pack.
    This ensures templates always ship the latest JS matching the framework version.
  -->
  <Target Name="SyncAbiesJsToTemplates" BeforeTargets="Build;Pack"
          Inputs="..\Picea.Abies.Browser\wwwroot\abies.js;..\Picea.Abies.Browser\wwwroot\abies-otel.js"
          Outputs="templates\abies-browser\wwwroot\abies.js;templates\abies-browser\wwwroot\abies-otel.js;templates\abies-browser-empty\wwwroot\abies.js;templates\abies-browser-empty\wwwroot\abies-otel.js">
    <Copy SourceFiles="..\Picea.Abies.Browser\wwwroot\abies.js;..\Picea.Abies.Browser\wwwroot\abies-otel.js"
          DestinationFolder="templates\abies-browser\wwwroot\" />
    <Copy SourceFiles="..\Picea.Abies.Browser\wwwroot\abies.js;..\Picea.Abies.Browser\wwwroot\abies-otel.js"
          DestinationFolder="templates\abies-browser-empty\wwwroot\" />
  </Target>

  <!--
    Sync abies-server.js from the canonical source (Picea.Abies.Server.Kestrel/wwwroot/_abies/)
    into the server template's wwwroot/_abies/ before build/pack.
    While UseAbiesStaticFiles() now serves from embedded resources (no file copying needed),
    bundling the JS directly ensures the template works even if the user removes that call
    and relies on standard UseStaticFiles() only.
  -->
  <Target Name="SyncAbiesServerJsToTemplates" BeforeTargets="Build;Pack"
          Inputs="..\Picea.Abies.Server.Kestrel\wwwroot\_abies\abies-server.js"
          Outputs="templates\abies-server\wwwroot\_abies\abies-server.js">
    <Copy SourceFiles="..\Picea.Abies.Server.Kestrel\wwwroot\_abies\abies-server.js"
          DestinationFolder="templates\abies-server\wwwroot\_abies\" />
  </Target>

</Project>
