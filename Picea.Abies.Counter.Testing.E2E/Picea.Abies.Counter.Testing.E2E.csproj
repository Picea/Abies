<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <OutputType>Exe</OutputType>
  </PropertyGroup>

  <ItemGroup>
    <Using Include="TUnit.Core.Interfaces" />
  </ItemGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Playwright" Version="1.59.0" />
    <PackageReference Include="TUnit" Version="1.33.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Picea.Abies.Counter\Picea.Abies.Counter.csproj" />
    <ProjectReference Include="..\Picea.Abies.Server.Kestrel\Picea.Abies.Server.Kestrel.csproj" />
    <!-- Build-order dependency: ensure Counter.Wasm is built before our
         PublishWasmProject target runs dotnet publish on it. Without this,
         parallel MSBuild can trigger two simultaneous publishes that race
         on ILLinker file locks. ReferenceOutputAssembly=false means we
         don't actually reference its output — just enforce ordering. -->
    <ProjectReference Include="..\Picea.Abies.Counter.Wasm\Picea.Abies.Counter.Wasm.csproj"
                      ReferenceOutputAssembly="false"
                      SkipGetTargetFrameworkProperties="true"
                      Private="false" />
    <!-- Build-order dependency on Host: Host also publishes Counter.Wasm via
         its own PublishWasmProject target. Without this ordering constraint,
         both Host and E2E race on the same WASM publish output directory.
         By depending on Host, it publishes first and our PublishWasmProject
         target sees the existing output and skips (via Inputs/Outputs). -->
    <ProjectReference Include="..\Picea.Abies.Counter.Wasm.Host\Picea.Abies.Counter.Wasm.Host.csproj"
                      ReferenceOutputAssembly="false"
                      SkipGetTargetFrameworkProperties="true"
                      Private="false" />
  </ItemGroup>

  <!--
    Publish the WASM project before build so that its AppBundle is available
    for the E2E test fixture to serve via UseAbiesWasmFiles().

    Same MSBuild strategy as Picea.Abies.Counter.Wasm.Host — invoke dotnet publish
    on the browser-wasm project to produce the AppBundle.
  -->
  <PropertyGroup>
    <WasmProjectPath>..\Picea.Abies.Counter.Wasm\Picea.Abies.Counter.Wasm.csproj</WasmProjectPath>
    <WasmAppBundlePath>..\Picea.Abies.Counter.Wasm\bin\$(Configuration)\net10.0\browser-wasm\AppBundle</WasmAppBundlePath>
  </PropertyGroup>

  <Target Name="PublishWasmProject" BeforeTargets="Build"
          Inputs="$(WasmProjectPath)"
          Outputs="$(WasmAppBundlePath)\_framework\dotnet.js">
    <Exec Command="dotnet publish &quot;$(WasmProjectPath)&quot; -c $(Configuration)"
          ConsoleToMSBuild="true" />
  </Target>

</Project>
