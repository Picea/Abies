<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Standalone doc-snippet compile checker.
    Intentionally NOT part of Picea.Abies.sln so it can never affect packaging.
    See .github/workflows/docs-snippets.yml.
  -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>preview</LangVersion>
    <!-- Keep this project hermetic from repo-wide Directory.Build.* settings that
         might pull in analyzers/treat-warnings-as-errors and slow us down. -->
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="5.3.0" />
    <PackageReference Include="Basic.Reference.Assemblies.Net100" Version="1.8.8" />
  </ItemGroup>

</Project>
