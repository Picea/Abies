<Project>
  <!--
    Source-build parity: when building this repository via ProjectReference,
    buildTransitive package targets are not imported. Inject the same Debug-only
    MetadataUpdateHandler registration automatically for projects that directly
    reference Picea.Abies.
  -->

  <PropertyGroup>
    <EnableAbiesMetadataUpdateHandlerAutoInject Condition="'$(EnableAbiesMetadataUpdateHandlerAutoInject)' == ''">true</EnableAbiesMetadataUpdateHandlerAutoInject>
  </PropertyGroup>

  <Target Name="GenerateAbiesMetadataUpdateHandlerFromProjectReference"
          BeforeTargets="CoreCompile"
          Condition="'$(EnableAbiesMetadataUpdateHandlerAutoInject)' == 'true' and '$(Language)' == 'C#' and '$(Configuration)' == 'Debug'">
    <ItemGroup>
      <_AbiesProjectRefLocal Include="@(ProjectReference)"
                             Condition="$([System.String]::new('%(Identity)').Contains('Picea.Abies.csproj'))" />
    </ItemGroup>

    <PropertyGroup>
      <_AbiesMetadataUpdateHandlerFile>$(IntermediateOutputPath)Abies.MetadataUpdateHandler.g.cs</_AbiesMetadataUpdateHandlerFile>
    </PropertyGroup>

    <ItemGroup>
      <_AbiesMetadataUpdateHandlerLines Include="// &lt;auto-generated/&gt;" />
      <_AbiesMetadataUpdateHandlerLines Include="#if DEBUG" />
      <_AbiesMetadataUpdateHandlerLines Include="[assembly: System.Reflection.Metadata.MetadataUpdateHandler(typeof(Picea.Abies.AbiesMetadataUpdateHandler))]" />
      <_AbiesMetadataUpdateHandlerLines Include="#endif" />
    </ItemGroup>

    <WriteLinesToFile File="$(_AbiesMetadataUpdateHandlerFile)"
                      Lines="@(_AbiesMetadataUpdateHandlerLines)"
                      Overwrite="true"
                      WriteOnlyWhenDifferent="true"
                      Condition="'@(_AbiesProjectRefLocal)' != ''" />

    <ItemGroup>
      <Compile Include="$(_AbiesMetadataUpdateHandlerFile)"
               Visible="false"
               AutoGen="true"
               DesignTime="true"
               Condition="'@(_AbiesProjectRefLocal)' != ''" />
    </ItemGroup>
  </Target>
</Project>
