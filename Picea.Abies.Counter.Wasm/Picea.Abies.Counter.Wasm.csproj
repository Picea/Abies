<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RuntimeIdentifier>browser-wasm</RuntimeIdentifier>
    <OutputType>Exe</OutputType>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <!-- Praefixum source generator uses interceptors to replace UniqueId calls at compile time. -->
    <InterceptorsNamespaces>$(InterceptorsNamespaces);Praefixum</InterceptorsNamespaces>
    <!-- This project only targets browser-wasm, suppress platform compatibility warnings. -->
    <NoWarn>CA1416</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Picea.Abies.Browser\Picea.Abies.Browser.csproj" />
    <ProjectReference Include="..\Picea.Abies.Counter\Picea.Abies.Counter.csproj" />
  </ItemGroup>

  <!-- Copy wwwroot files to the AppBundle output directory after WASM bundle generation. -->
  <Target Name="CopyWwwrootToAppBundle" AfterTargets="WasmGenerateAppBundle">
    <ItemGroup>
      <WwwrootFiles Include="wwwroot\**\*" />
    </ItemGroup>
    <Copy SourceFiles="@(WwwrootFiles)"
          DestinationFiles="@(WwwrootFiles->'$(OutputPath)AppBundle\%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />
  </Target>

  <!-- Copy the canonical abies.js from the Picea.Abies.Browser library to AppBundle. -->
  <Target Name="CopyAbiesJs" AfterTargets="CopyWwwrootToAppBundle"
          Inputs="..\Picea.Abies.Browser\wwwroot\abies.js"
          Outputs="$(OutputPath)AppBundle\abies.js">
    <Copy SourceFiles="..\Picea.Abies.Browser\wwwroot\abies.js"
          DestinationFiles="$(OutputPath)AppBundle\abies.js" />
  </Target>

</Project>
